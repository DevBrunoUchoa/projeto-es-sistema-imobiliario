# ===========================================================================
# Modelo de variáveis de ambiente.
# Copie para .env e ajuste os valores. O arquivo .env NÃO é versionado.
#   cp .env.example .env
# ===========================================================================

# --- Banco de dados (PostgreSQL / PostGIS) ---
POSTGRES_DB=campus_living
POSTGRES_USER=campus_living
POSTGRES_PASSWORD=troque-este-valor
POSTGRES_PORT=5432

# --- Aplicação (Spring Boot) ---
# Profiles disponíveis: dev | test | prod
SPRING_PROFILES_ACTIVE=dev
APP_PORT=8080

# --- Supabase Storage (fotos dos anuncios) ---
# Crie um bucket PUBLICO chamado "anuncios" no painel do Supabase.
# A service role key e exclusiva do backend e nunca deve ir para o frontend.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=anuncios

# --- Datasource ---
# DEV: opcional. Se omitido, usa jdbc:postgresql://localhost:5432/${POSTGRES_DB}.
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/campus_living
#
# PROD: obrigatórias (sem fallback). Defina-as no ambiente do provedor de nuvem
# (ex.: painel do Render), nunca num arquivo commitado.
#
# Use a string do SESSION POOLER do Supabase (não a "Direct connection", que é
# só IPv6 no free tier, e a maioria dos hosts de aplicação — Render incluso —
# não fala IPv6 de saída). Pegue em Supabase > Project Settings > Database >
# Connection string > "Session pooler":
#
#   SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-<regiao>.pooler.supabase.com:5432/postgres
#   SPRING_DATASOURCE_USERNAME=postgres.<project-ref>
#   SPRING_DATASOURCE_PASSWORD=<senha do banco>
#
# Por quê "session" e não "transaction" pooler (porta 6543)? O transaction
# pooler compartilha uma mesma conexão real entre vários clientes diferentes a
# cada transação — ótimo para escalar muito (ex.: funções serverless), mas
# quebra prepared statements do Hibernate a menos que você desative o cache de
# statements (?prepareThreshold=0 na URL) e evite features de sessão. Como o
# HikariCP já faz o próprio pool de conexões do lado da aplicação, o session
# pooler (semântica de conexão normal, só resolve o problema de IPv4) é a
# opção mais simples e já suficiente pro volume de um projeto acadêmico.
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# --- Pool de conexões (HikariCP) — opcional, só usado no profile prod ---
# Ajuste conforme o limite de conexões do plano do provedor (ex.: Supabase
# free tier costuma limitar bem o total de conexões simultâneas).
# DB_POOL_MAX_SIZE=10
# DB_POOL_MIN_IDLE=2
